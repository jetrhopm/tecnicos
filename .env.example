APP_NAME="Sistema Web de Gestion de Servicios Tecnicos y Reparaciones"
APP_ENV=local
APP_DEBUG=true
APP_URL=auto
APP_TIMEZONE=America/Mexico_City
# Pon true solo si la app corre detras de un proxy/balanceador que manda X-Forwarded-*
APP_TRUST_PROXY=false

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=servicio_tecnico_db
DB_USERNAME=root
DB_PASSWORD=rufles123
DB_CHARSET=utf8mb4

SESSION_NAME=servicio_tecnico_session
UPLOAD_MAX_MB=8

# Cierre de sesion por inactividad (minutos) y duracion de "No cerrar sesion" (dias)
SESSION_IDLE_MINUTES=120
SESSION_REMEMBER_DAYS=30
